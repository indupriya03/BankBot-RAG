# Choose ONE provider and fill in its key — comment out the others

# Option 1: OpenAI
# OPENAI_API_KEY=your_openai_key_here

# Option 2: Groq (free tier, fast inference, open-source models)
GROQ_API_KEY=your_groq_key_here

# Option 3: HuggingFace (for local/free open-source models)
# HUGGINGFACE_API_KEY=your_hf_key_here

# DagsHub (for DVC + MLflow remote)
DAGSHUB_TOKEN=your_dagshub_token_here

# Which LLM provider to use — controls app/orchestrator logic
LLM_PROVIDER=groq
